# Chaves Públicas e Privadas Necessárias
# Copie este arquivo para .env.local para configurar a aplicação localmente.

# =============================================================================
# CORE — STACK EXISTENTE (v0.9)
# =============================================================================

# Stripe Keys (Account Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bags SDK (Obrigatório para integração real)
# Obtenha sua API key em: https://dev.bags.fm
BAGS_API_KEY=your_bags_api_key_here

# Solana RPC (Mainnet para produção, devnet para testes)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Criptografia AES-256-GCM (32 bytes = 64 chars hex)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your_64_char_hex_string_here

# =============================================================================
# GOD STACK — MÓDULOS AVANÇADOS
# =============================================================================
# Todas as flags abaixo são FALSE por padrão.
# Ative somente após configurar as variáveis do módulo correspondente.

# -----------------------------------------------------------------------------
# MÓDULO 1: ZK Compression (Light Protocol + Helius)
# -----------------------------------------------------------------------------
# Ative quando: HELIUS_API_KEY configurado e devnet ZK disponível
ENABLE_ZK_COMPRESSION=false

# Helius API Key — RPC com suporte a ZK proofs
# Obtenha em: https://helius.dev (plano gratuito suficiente para devnet)
HELIUS_API_KEY=your_helius_api_key_here

# RPC URL com suporte ZK (Helius devnet ou mainnet)
# Devnet:  https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Mainnet: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
LIGHT_PROTOCOL_RPC=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here

# -----------------------------------------------------------------------------
# MÓDULO 2: Gasless Engine (Fee Payer)
# -----------------------------------------------------------------------------
# Ative quando: FEE_PAYER_SECRET_KEY gerado e com saldo SOL devnet
ENABLE_GASLESS=false

# Keypair do Fee Payer (base64 do Uint8Array de 64 bytes)
# Gerado automaticamente pelo script: npm run setup:fee-payer
# NUNCA commitar este valor — apenas no .env.local
FEE_PAYER_SECRET_KEY=base64_encoded_64_byte_keypair_here

# Limites de segurança do relayer
RELAYER_MAX_SOL_PER_TX=0.005
RELAYER_DAILY_LIMIT_SOL=1.0

# -----------------------------------------------------------------------------
# MÓDULO 3: Token BXP (Token-2022)
# -----------------------------------------------------------------------------
# Ative quando: token criado via script npm run create:bxp-token
ENABLE_BXP_TOKEN=false

# Mint address do token BXP em devnet
# Gerado pelo script: npm run create:bxp-token
BXP_TOKEN_MINT=MINT_ADDRESS_AFTER_CREATION
BXP_TOKEN_DECIMALS=6
BXP_TOTAL_SUPPLY=1000000000

# Keypair da wallet issuer/distributor do BXP (base64)
# Gerado pelo script de criação do token
BXP_ISSUER_SECRET_KEY=base64_encoded_issuer_keypair_here
BXP_DISTRIBUTOR_SECRET_KEY=base64_encoded_distributor_keypair_here

# -----------------------------------------------------------------------------
# MÓDULO 4: Anchor Smart Contracts
# -----------------------------------------------------------------------------
# Ative quando: programa deployado em devnet
ENABLE_ANCHOR=false

# Program ID do contrato BagxPress Vault após deploy
# Obtido com: anchor deploy --provider.cluster devnet
BAGXPRESS_PROGRAM_ID=PROGRAM_ID_AFTER_DEPLOY

# -----------------------------------------------------------------------------
# MÓDULO 5: Debug / Developer Mode
# -----------------------------------------------------------------------------
# Nunca ativar em produção — logs detalhados de todos os módulos
GOD_STACK_DEBUG=false
